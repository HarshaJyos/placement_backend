# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"

# Redis Cache & Queue Configuration
REDIS_URL="redis://localhost:6379"

# Cryptographic & Authentication Secrets
JWT_ACCESS_SECRET="generate-secure-jwt-access-secret"
JWT_REFRESH_SECRET="generate-secure-jwt-refresh-secret"
OTP_HMAC_SECRET="generate-secure-otp-hmac-sha256-secret"

# Cloudflare R2 / AWS S3 Compatible File Storage
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_BUCKET_NAME="your-bucket-name"
